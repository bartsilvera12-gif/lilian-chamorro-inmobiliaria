# Desarrollo: copiar a `.env.local` (gitignore).
# Producción / `npm run build`: Vite carga `.env.production` o variables del hosting.
#
# Vite solo inyecta variables con prefijo VITE_
# Ejemplo self-hosted: https://api.tudominio.com.py
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Schema PostgreSQL de negocio (PostgREST / supabase-js).
# Requisito en Supabase (hosted): Dashboard → Settings → API → Exposed schemas → añadir lilian_inmobiliaria.
# Luego aplicar migraciones (incl. grants). Sin eso verás "Invalid schema: lilian_inmobiliaria".
VITE_BUSINESS_SCHEMA=lilian_inmobiliaria

# Opcional: compatibilidad si usás variables estilo Next en el mismo archivo
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_BUSINESS_SCHEMA=lilian_inmobiliaria

# Cotización PYG por 1 USD (ordenar precios mixtos USD/PYG y calculadora)
# VITE_PYG_PER_USD=7500

# Filas por request al paginar properties (25–1000; default en código 500 si no definís esta var)
# VITE_SUPABASE_PAGE_SIZE=500

# Solo para script local: npm run create-admin (nunca commitear la clave real)
# SUPABASE_SERVICE_ROLE_KEY=
